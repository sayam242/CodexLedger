generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id
  name      String
  email     String    @unique
  photoUrl  String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  problems  Problem[]
  
}

model Problem {
  id            String          @id @default(uuid())
  platform      String
  problemNumber String?
  title         String
  slug          String
  url           String
  difficulty    String
  solved        Boolean         @default(false)
  userId        String
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  content       ProblemContent?
  topics        ProblemTopic[]
  submissions   Submission[]
  note          ProblemNote?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@unique([userId, slug])
  @@index([userId])
}

model ProblemContent {
  id        String @id @default(uuid())
  problemId String @unique

  htmlContent String
  plainText   String
  problem     Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum AIAnalysisStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model Submission {
  id                           String   @id @default(uuid())

  problemId                    String
  language                     String
  code                         String

  status                       String?
  errorMessage                 String?
  submittedAt                  DateTime

  // -----------------------------
  // AI Complexity Analysis
  // -----------------------------

  timeComplexity               String?
  spaceComplexity              String?

  timeComplexityOptions         Json?
  spaceComplexityOptions        Json?

  complexityReasoning           String?

  complexityAnalysisStatus      AIAnalysisStatus @default(PENDING)
  complexityAnalysisVersion     Int              @default(1)
  complexityGeneratedAt         DateTime?

  // -----------------------------
  // Quiz Progress
  // -----------------------------

  complexityQuizCompleted       Boolean  @default(false)
  complexityQuizCompletedAt     DateTime?

  // -----------------------------
  // Relations
  // -----------------------------

  problem                       Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)

  createdAt                     DateTime @default(now())
  updatedAt                     DateTime @updatedAt

  @@unique([problemId, submittedAt])
  @@index([problemId])
  @@index([complexityAnalysisStatus])
}

model Topic {
  id        String         @id @default(uuid())
  name      String         @unique
  problems  ProblemTopic[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model ProblemTopic {
  problemId String
  topicId   String
  problem   Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)
  topic     Topic   @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@id([problemId, topicId])
  @@index([topicId])
}

model ProblemNote {
  id         String   @id @default(cuid())

  problemId  String   @unique

  content    String   

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  problem     Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)
}
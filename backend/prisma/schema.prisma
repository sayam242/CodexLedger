generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String       @id
  name        String
  email       String       @unique
  photoUrl    String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  submissions Submission[]
  notes       ProblemNote[]
}

model Problem {
  id            String              @id @default(uuid())
  platform      String
  problemNumber String?
  title         String
  slug          String
  url           String
  difficulty    String
  explanation   ProblemExplanation?
  content       ProblemContent?
  topics        ProblemTopic[]
  submissions   Submission[]
  notes         ProblemNote[]
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@unique([problemNumber])
  @@unique([title])
}

model ProblemContent {
  id        String @id @default(uuid())
  problemId String @unique

  htmlContent String
  plainText   String
  problem     Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum AIAnalysisStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model Submission {
  id                           String   @id @default(uuid())

  problemId                    String
  userId                       String
  language                     String
  code                         String

  status                       String?
  errorMessage                 String?
  submittedAt                  DateTime

  // -----------------------------
  // AI Complexity Analysis
  // -----------------------------

  timeComplexity               String?
  spaceComplexity              String?

  timeComplexityOptions         Json?
  spaceComplexityOptions        Json?

  complexityReasoning           String?

  complexityAnalysisStatus      AIAnalysisStatus @default(PENDING)
  complexityAnalysisVersion     Int              @default(1)
  complexityGeneratedAt         DateTime?

  // -----------------------------
  // Quiz Progress
  // -----------------------------

  complexityQuizCompleted       Boolean  @default(false)
  complexityQuizCompletedAt     DateTime?

  // -----------------------------
  // Relations
  // -----------------------------

  problem                       Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)
  user                          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt                     DateTime @default(now())
  updatedAt                     DateTime @updatedAt

  @@unique([problemId, userId, submittedAt])
  @@index([problemId])
  @@index([userId])
  @@index([complexityAnalysisStatus])
}

model Topic {
  id        String         @id @default(uuid())
  name      String         @unique
  problems  ProblemTopic[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model ProblemTopic {
  problemId String
  topicId   String
  problem   Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)
  topic     Topic   @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@id([problemId, topicId])
  @@index([topicId])
}

model ProblemNote {
  id         String   @id @default(cuid())

  problemId  String
  userId     String
  content    String   

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  problem     Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([problemId, userId])
}



model ProblemExplanation {
  id                     String   @id @default(uuid())

  problemId              String   @unique

  explanation            Json

  analysisStatus         AIAnalysisStatus @default(PENDING)

  version                Int      @default(1)

  generatedAt            DateTime?

  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  problem                Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@index([analysisStatus])
}